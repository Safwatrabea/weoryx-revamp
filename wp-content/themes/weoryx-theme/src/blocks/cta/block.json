{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "weoryx/cta",
    "version": "1.0.0",
    "title": "Call to Action",
    "category": "weoryx",
    "icon": "megaphone",
    "description": "Call to Action section",
    "attributes": {
        "title": {
            "type": "string",
            "default": "Ready to Start Your Project?"
        },
        "description": {
            "type": "string",
            "default": "Let's discuss how we can help you achieve your digital marketing goals. Get a free consultation today!"
        },
        "buttonText": {
            "type": "string",
            "default": "Contact Us"
        },
        "buttonUrl": {
            "type": "string",
            "default": "/contact"
        }
    },
    "supports": {
        "html": false,
        "anchor": true
    },
    "textdomain": "weoryx",
    "editorScript": "weoryx-cta-block-editor",
    "render": "file:./render.php"
}